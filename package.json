{
  "name": "relay-session",
  "version": "1.0.0",
  "description": "TypeScript-first session middleware for Express with session rotation, locking and pluggable stores.",
  "license": "MIT",
  "author": "Pascal Pfeifer <pascal@pfeifer.zone>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "express",
    "session",
    "middleware",
    "nodejs",
    "session-store",
    "session-management",
    "typescript",
    "express-session-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pfeiferio/relay-session.git"
  },
  "bugs": {
    "url": "https://github.com/pfeiferio/relay-session/issues"
  },
  "homepage": "https://github.com/pfeiferio/relay-session#readme",
  "engines": {
    "node": ">=18.15.0"
  },
  "peerDependencies": {
    "express": "^4 || ^5",
    "request-drain": "^1.1.1"
  },
  "peerDependenciesMeta": {
    "request-drain": {
      "optional": true
    }
  },
  "dependencies": {
    "@pfeiferio/dotpath-utils": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='test/**'",
    "test:coverage:c8": "npm run build && npx c8 node --test",
    "test:coverage:lcov": "npm run build && npx c8 --src src node --enable-source-maps --test"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "request-drain": "^1.1.1"
  }
}
